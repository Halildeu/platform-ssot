{
  "version": "v1",
  "kind": "prod-github-environment-secret-map",
  "environment": "prod",
  "source_of_truth": {
    "vault_path": "secret/prod/ops/github/backend-deploy",
    "sync_workflow": ".github/workflows/vault-secrets-sync.yml",
    "sync_mode": "backend-deploy",
    "secret_scope": "environment",
    "github_environment": "prod"
  },
  "required_secrets": [
    {
      "name": "BACKEND_SSH_DEPLOY_ENABLED",
      "required": true,
      "purpose": "Prod backend SSH deploy akisini enable eder",
      "expected_shape": "boolean-string"
    },
    {
      "name": "BACKEND_DEPLOY_SSH_HOST",
      "required": true,
      "purpose": "Prod backend host hedefi",
      "expected_shape": "hostname-or-ip"
    },
    {
      "name": "BACKEND_DEPLOY_SSH_PORT",
      "required": true,
      "purpose": "Prod backend SSH portu",
      "expected_shape": "integer-string"
    },
    {
      "name": "BACKEND_DEPLOY_SSH_USER",
      "required": true,
      "purpose": "Prod deploy kullanicisi",
      "expected_shape": "username"
    },
    {
      "name": "BACKEND_DEPLOY_SSH_KEY",
      "required": true,
      "purpose": "GitHub Actions -> prod host deploy anahtari",
      "expected_shape": "multiline-private-key"
    },
    {
      "name": "BACKEND_DEPLOY_SSH_KNOWN_HOSTS",
      "required": true,
      "purpose": "SSH host key pinning",
      "expected_shape": "known-hosts-entry"
    },
    {
      "name": "BACKEND_DEPLOY_REMOTE_ENV_FILE",
      "required": true,
      "purpose": "Prod backend.env hedef yolu",
      "expected_shape": "absolute-path"
    },
    {
      "name": "BACKEND_DEPLOY_REMOTE_REPO_DIR",
      "required": true,
      "purpose": "Prod repo checkout yolu",
      "expected_shape": "absolute-path"
    },
    {
      "name": "BACKEND_DEPLOY_REMOTE_COMPOSE_PROFILES",
      "required": false,
      "purpose": "Report veya schema servisleri aciksa compose profile listesi",
      "expected_shape": "csv"
    },
    {
      "name": "BACKEND_HEALTH_URLS",
      "required": true,
      "purpose": "Post-deploy validate tarafinda backend health endpoint listesi",
      "expected_shape": "csv-url-list"
    }
  ],
  "recommended_environment_controls": [
    "required reviewers",
    "manual approval before prod deploy",
    "deployment branch restrictions",
    "repo-level duplicate BACKEND_* secret cleanup after prod environment adoption"
  ]
}
