        "GH_AUTH_VAULT_PATH",
        "GH_AUTH_VAULT_FIELD"
      ],
      "outputs": []
    },
    {
      "id": "ROB-0100",
      "name": "auto-fix",
      "kind": "workflow",
      "path": ".github/workflows/auto-fix.yml",
      "default_mode": "plan",
      "allowed_modes": [
        "plan"
      ],
      "side_effects": [
        "workflow_dispatch(auto-fix)",
        "notice_only (disabled by Local SSOT policy)"
      ],
      "required_auth_refs": [
        "TOK-0001"
      ],
      "required_env": [
        "GH_TOKEN|GITHUB_TOKEN|VaultPointer"
      ],
      "required_confirm": null,
      "inputs": [
        "ref=main"
      ],
      "outputs": [
        "artifacts/ci-logs/run-<id>/* (via scripts/ops/gh_pull_run_logs.sh)"
      ],
      "notes": [
        "refined: risky_top5 v0.1"
      ]
    },
    {
      "id": "ROB-0101",
      "name": "deploy-backend",
      "kind": "workflow",
      "path": ".github/workflows/deploy-backend.yml",
      "default_mode": "plan",
      "allowed_modes": [
        "plan",
        "apply"
      ],
      "side_effects": [
        "push(main) triggers deploy-backend",
        "workflow_dispatch(deploy-backend)",
        "docker_build_push(ghcr.io) via GitHub Actions runner"
      ],
      "required_auth_refs": [
        "TOK-0001"
      ],
      "required_env": [
        "GH_TOKEN|GITHUB_TOKEN|VaultPointer",
        "DEPLOY_ENABLED (GitHub secret, must be \"true\")"
      ],
      "required_confirm": "DEPLOY",
      "inputs": [
        "ref=main",
        "workflow_dispatch.inputs.env (default: stage)"
      ],
      "outputs": [
        "ghcr.io/<owner>/platform-ssot-<svc>:sha-<sha7>",
        "ghcr.io/<owner>/platform-ssot-<svc>:main-stable",
        "artifacts/ci-logs/main-<sha7>/* (via scripts/ops/ci_pull_deploy_chain_logs.sh)"
      ],
      "notes": [
        "refined: risky_top5 v0.1"
      ]
    },
    {
      "id": "ROB-0102",
      "name": "deploy-web",
      "kind": "workflow",
      "path": ".github/workflows/deploy-web.yml",
      "default_mode": "plan",
      "allowed_modes": [
        "plan",
        "apply"
      ],
      "side_effects": [
        "push(main) triggers deploy-web",
        "workflow_dispatch(deploy-web)",
        "curl_post(WEB_DEPLOY_HOOK_URL)"
      ],
      "required_auth_refs": [
        "TOK-0001"
      ],
      "required_env": [
        "GH_TOKEN|GITHUB_TOKEN|VaultPointer",
        "DEPLOY_ENABLED (GitHub secret, must be \"true\")",
        "WEB_DEPLOY_HOOK_URL (GitHub secret)"
      ],
      "required_confirm": "DEPLOY",
      "inputs": [
        "ref=main",
        "workflow_dispatch.inputs.env (default: stage)"
      ],
      "outputs": [
        "deploy hook triggered (external)",
        "artifacts/ci-logs/main-<sha7>/* (via scripts/ops/ci_pull_deploy_chain_logs.sh)"
      ],
      "notes": [
        "refined: risky_top5 v0.1"
      ]
    },
