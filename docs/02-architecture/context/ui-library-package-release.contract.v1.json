{
  "version": "1.0",
  "contract_id": "ui-library-package-release-contract-v1",
  "subject_id": "ui_kutuphane_sistemi",
  "package_name": "mfe-ui-kit",
  "package_json_path": "web/packages/ui-kit/package.json",
  "purpose": "UI kit package versioning, changelog, build artefact ve dagitim kanitini fail-closed release kontrati altinda toplamak.",
  "versioning_strategy": {
    "source_of_truth": "web/packages/ui-kit/package.json:version",
    "scheme": "semver",
    "rules": {
      "major": "stable component API'sinde backward incompatible degisiklik veya kaldirilma",
      "minor": "yeni exported component, yeni variant axis veya backward compatible capability genislemesi",
      "patch": "bugfix, a11y duzeltmesi, visual regression fix, docs/preview parity duzeltmesi"
    },
    "prerelease_channels": [
      "beta",
      "rc"
    ],
    "lifecycle_mapping": {
      "planned": "release edilmez",
      "beta": "preview/docs/gate PASS ile kontrollu adoption",
      "stable": "release notes ve canary evidence ile yayimlanabilir",
      "deprecated": "replacement + migration note olmadan yeni release icinde yalniz deprecate edilir"
    }
  },
  "distribution_targets": [
    {
      "target_id": "module_federation_remote",
      "channel": "internal-web-runtime",
      "build_command": "npm -C web run build:ui-kit",
      "artifact_paths": [
        "web/packages/ui-kit/dist/remoteEntry.js"
      ]
    },
    {
      "target_id": "publish_bundle",
      "channel": "bundle-drop",
      "build_command": "npm -C web run publish:bundle",
      "artifact_paths": [
        "web/dist/ui-kit/remoteEntry.js"
      ]
    },
    {
      "target_id": "storybook_static",
      "channel": "docs-static",
      "build_command": "npm -C web run build-storybook",
      "artifact_paths": [
        "web/storybook-static/index.html"
      ]
    },
    {
      "target_id": "chromatic",
      "channel": "hosted-docs-review",
      "build_command": "npm -C web run chromatic",
      "artifact_paths": []
    },
    {
      "target_id": "release_manifest",
      "channel": "release-evidence",
      "build_command": "npm -C web run release:ui-library:manifest",
      "artifact_paths": [
        "web/dist/ui-kit/ui-library-release-manifest.v1.json",
        "web/test-results/releases/ui-library/latest/ui-library-release-manifest.v1.json"
      ]
    }
  ],
  "required_scripts": [
    "build:ui-kit",
    "build-storybook",
    "chromatic",
    "publish:bundle",
    "release:ui-library:manifest",
    "release:ui-library",
    "security:build-bundle",
    "doctor:frontend",
    "gate:ui-library-wave",
    "gate:ui-library-release"
  ],
  "release_evidence": {
    "required_files": [
      "web/packages/ui-kit/package.json",
      "web/packages/ui-kit/src/catalog/component-registry.v1.json",
      "web/packages/ui-kit/src/catalog/component-api-catalog.v1.json",
      "docs/04-operations/RELEASE-NOTES/RELEASE-NOTES-ui-library.md",
      "docs/02-architecture/context/ui-library-package-release.contract.v1.json",
      "docs/04-operations/RUNBOOKS/RB-ui-library-package-release.md",
      ".github/workflows/ui-library-package-release.yml",
      "web/scripts/ops/export-ui-library-release-manifest.mjs",
      "web/scripts/ops/run-ui-library-release-gate.mjs",
      "web/scripts/ops/run-ui-library-release.mjs"
    ],
    "required_artifacts": [
      "web/apps/mfe-shell/src/pages/admin/design-lab.index.json",
      "web/test-results/diagnostics/frontend-doctor/**/frontend-doctor.summary.v1.json",
      "web/test-results/diagnostics/ui-library-wave-gate/**/ui-library-wave-gate.summary.v1.json",
      "web/test-results/diagnostics/ui-library-release-gate/**/ui-library-release-gate.summary.v1.json",
      "web/test-results/releases/ui-library/latest/ui-library-release-manifest.v1.json",
      "web/test-results/releases/ui-library/latest/ui-library-release.summary.v1.json"
    ],
    "required_human_log": [
      "release note entry",
      "stable veya beta lifecycle degisikligi notu",
      "breaking degisiklik varsa migration note",
      "runbook linki",
      "test plan linki"
    ]
  },
  "changelog_policy": {
    "release_notes_path": "docs/04-operations/RELEASE-NOTES/RELEASE-NOTES-ui-library.md",
    "entry_minimums": [
      "version",
      "date",
      "changed components",
      "lifecycle changes",
      "breaking changes",
      "migration notes",
      "evidence references",
      "runbook link",
      "test plan link"
    ],
    "stable_release_requires": [
      "doctor frontend PASS",
      "release gate PASS",
      "release notes entry",
      "ui-library release manifest",
      "release runbook linki"
    ]
  },
  "fail_closed_rules": [
    "package version degisiyorsa release notes entry yoksa release hazir sayilmaz",
    "registry lifecycle degisikligi varsa component API catalog ve Design Lab parity olmadan release hazir sayilmaz",
    "storyboard/chromatic/publish bundle scriptleri kayitli degilse dagitim kontrati FAIL olur",
    "stable veya breaking degisiklikte release gate PASS kaniti olmadan version bump tamam sayilmaz",
    "release manifest uretmeden publish bundle dagitim kaniti tamam sayilmaz",
    "module federation remote './library' expose etmeden ui-kit release hazir sayilmaz"
  ],
  "success_criteria": [
    "UI kit versiyon artislari semver kuralina gore acik sekilde siniflanir.",
    "Dagitim hedefleri, build komutu ve artefact kaniti tek kontratta gorunur olur.",
    "Release notes olmadan sessiz paket davranis degisikligi yapilmaz."
  ]
}
