{
  "version": "1.0",
  "registry_id": "frontend-diagnostics-registry-v1",
  "subject_id": "frontend_diagnostics_control_plane",
  "title": "Frontend Diagnostics Control Plane",
  "purpose": "Tarayici runtime hatalari, route smoke, auth drift, remote federation hatalari ve frontend kalite kapilarini tek JSON-first envanter ve doctor akisi altinda toplamak.",
  "canonical_entrypoints": [
    "docs/02-architecture/context/frontend-diagnostics.registry.v1.json",
    "web/scripts/ops/frontend-doctor.mjs",
    "web/tests/playwright/pw_scenarios.yml",
    "web/tests/playwright/scenario-runner.spec.ts",
    "web/tests/playwright/utils/pw_telemetry.ts",
    "docs/04-operations/RUNBOOKS/RB-web-playwright-smoke.md",
    "docs/04-operations/RUNBOOKS/RB-frontend-doctor.md"
  ],
  "diagnostic_layers": [
    {
      "layer_id": "browser_runtime_telemetry",
      "status": "active",
      "owner": "web/tests/playwright/utils/pw_telemetry.ts",
      "signals": [
        "pageerror",
        "console.error",
        "console.warn",
        "xhr_fetch_401_403_5xx",
        "requestfailed",
        "readonly_violation",
        "resource_load_failure",
        "unhandled_rejection",
        "runtime_overlay"
      ],
      "artifacts": [
        "web/test-results/pw/pw-scenario-*.md",
        "web/test-results/pw/pw-summary-*.md",
        "web/test-results/pw/artifacts/**"
      ]
    },
    {
      "layer_id": "playwright_yaml_scenario_runner",
      "status": "active",
      "owner": "web/tests/playwright/scenario-runner.spec.ts",
      "inputs": [
        "web/tests/playwright/pw_scenarios.yml",
        "PLAYWRIGHT_BASE_URL",
        "PW_MODE",
        "PW_AUTH_MODE",
        "PW_SOFT_MODE"
      ],
      "signals": [
        "route_open_smoke",
        "interaction_click_walk",
        "step_journal_evidence"
      ],
      "artifacts": [
        "web/test-results/pw/pw-scenario-*.md",
        "web/test-results/pw/pw-summary-*.md",
        "web/test-results/pw/artifacts/**"
      ]
    },
    {
      "layer_id": "gateway_smoke",
      "status": "active",
      "owner": "web/tests/smoke/gateway-smoke.mjs",
      "signals": [
        "401_without_token",
        "200_with_demo_token",
        "trace_id_visibility"
      ],
      "artifacts": [
        "web/tests/smoke/artifacts/gateway-smoke.log"
      ]
    },
    {
      "layer_id": "local_nightly_integration",
      "status": "active",
      "owner": ".github/workflows/web-playwright-local-nightly.yml",
      "signals": [
        "backend_compose_boot",
        "mfe_boot",
        "playwright_nightly",
        "cleanup_integrity"
      ],
      "artifacts": [
        "web/test-results/pw/**",
        "web/test-results/ops/**"
      ]
    },
    {
      "layer_id": "ci_failure_digest",
      "status": "active",
      "owner": ".github/workflows/log-digest.yml",
      "signals": [
        "workflow_failure_first_block",
        "idempotent_pr_comment"
      ],
      "artifacts": [
        "PR comment marker: <!-- log-digest:v1 -->"
      ]
    },
    {
      "layer_id": "frontend_doctor",
      "status": "active",
      "owner": "web/scripts/ops/frontend-doctor.mjs",
      "signals": [
        "build_health",
        "lint_health",
        "route_runtime_health",
        "route_click_walk_health",
        "login_smoke_health",
        "gateway_smoke_health",
        "resource_load_health",
        "runtime_overlay_health"
      ],
      "artifacts": [
        "web/test-results/diagnostics/frontend-doctor/*/frontend-doctor.summary.v1.json",
        "web/test-results/diagnostics/frontend-doctor/*/frontend-doctor.summary.v1.md",
        "web/test-results/diagnostics/frontend-doctor/*/logs/*.log"
      ]
    }
  ],
  "route_coverage": [
    {
      "route_id": "shell_login",
      "path": "/login",
      "scenario_name": "shell_login",
      "auth_required": false,
      "owner": "mfe-shell"
    },
    {
      "route_id": "runtime_theme_matrix",
      "path": "/runtime/theme-matrix",
      "scenario_name": "runtime_theme_matrix",
      "auth_required": false,
      "owner": "mfe-shell"
    },
    {
      "route_id": "ui_library",
      "path": "/ui-library",
      "scenario_name": "ui_library_page",
      "auth_required": false,
      "owner": "mfe-shell"
    },
    {
      "route_id": "theme_admin",
      "path": "/admin/themes",
      "scenario_name": "theme_registry_page",
      "secondary_scenarios": [
        "theme_admin_navigation_walk"
      ],
      "auth_required": true,
      "owner": "mfe-shell"
    },
    {
      "route_id": "access_roles",
      "path": "/access/roles",
      "scenario_name": "access_roles_page",
      "auth_required": true,
      "owner": "mfe-access"
    },
    {
      "route_id": "audit_events",
      "path": "/audit/events",
      "scenario_name": "audit_events_page",
      "auth_required": true,
      "owner": "mfe-audit"
    },
    {
      "route_id": "reporting_users",
      "path": "/admin/reports/users",
      "scenario_name": "reporting_users_page",
      "auth_required": true,
      "owner": "mfe-reporting"
    }
  ],
  "doctor_presets": [
    {
      "preset_id": "ui-library",
      "description": "UI Library vitrini ve login/gateway smoke icin hizli lokal tanilama preset'i.",
      "steps": [
        "build:shell",
        "lint:tailwind",
        "test:shell(login)",
        "playwright:ui_library_page|ui_library_navigation_walk",
        "gateway_smoke",
        "base_url_fetch_check"
      ],
      "expected_artifacts": [
        "frontend-doctor.summary.v1.json",
        "frontend-doctor.summary.v1.md",
        "pw-scenario-ui-library-page-*.md",
        "pw-scenario-ui-library-navigation-walk-*.md",
        "pw-summary-*.md",
        "web/test-results/pw/artifacts/**",
        "gateway-smoke.log"
      ]
    },
    {
      "preset_id": "shell-public",
      "description": "Login, runtime theme matrix ve UI Library icin auth gerektirmeyen cekirdek shell tanilama preset'i.",
      "steps": [
        "build:shell",
        "lint:tailwind",
        "test:shell(login)",
        "playwright:shell_login|runtime_theme_matrix|ui_library_page|ui_library_navigation_walk|shell_public_route_walk",
        "gateway_smoke",
        "base_url_fetch_check"
      ],
      "expected_artifacts": [
        "frontend-doctor.summary.v1.json",
        "frontend-doctor.summary.v1.md",
        "pw-scenario-shell-login-*.md",
        "pw-scenario-runtime-theme-matrix-*.md",
        "pw-scenario-ui-library-page-*.md",
        "pw-scenario-ui-library-navigation-walk-*.md",
        "pw-scenario-shell-public-route-walk-*.md",
        "pw-summary-*.md",
        "web/test-results/pw/artifacts/**",
        "gateway-smoke.log"
      ]
    },
    {
      "preset_id": "theme-admin",
      "description": "Theme registry admin route'u icin auth gerekli diagnostics preset'i.",
      "steps": [
        "build:shell",
        "lint:tailwind",
        "playwright:theme_registry_page|theme_admin_navigation_walk",
        "gateway_smoke",
        "base_url_fetch_check"
      ],
      "requires_auth_mode": "token_injection",
      "runtime_mode": "mock-backed-auth-route",
      "expected_artifacts": [
        "frontend-doctor.summary.v1.json",
        "frontend-doctor.summary.v1.md",
        "pw-scenario-theme-registry-page-*.md",
        "pw-scenario-theme-admin-navigation-walk-*.md",
        "pw-summary-*.md",
        "web/test-results/pw/artifacts/**",
        "gateway-smoke.log"
      ]
    }
  ],
  "hard_rules": [
    "Yeni web route veya vitrin alani canonical senaryo olmadan tamamlanmis sayilmaz.",
    "Yeni etkileşimli vitrin veya admin route en az bir click-walk senaryosu olmadan tamamlanmis sayilmaz.",
    "Yeni UI library surface pageerror ve allowlist disi console.error üretirse release edilmez.",
    "Allowlist disi resource load failure, unhandled rejection veya runtime overlay varsa release edilmez.",
    "Doctor script mevcut telemetry hattini orkestre eder; ayri ikinci smoke sistemi kurulmaz.",
    "Diagnostics artifact'lari JSON-first ozet ve kanit dosyalari ile saklanir.",
    "Beklenen remote eksiklikleri allowlist ile acik yazilmadan gürültü görmezden gelinmez.",
    "Auth gerekli route diagnostics'i mümkünse mock-backed UI route seviyesinde kosulur; gercek client secret zorunlu kilinmaz."
  ]
}
