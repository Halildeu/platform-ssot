{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Quality Criteria (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "criteria_id",
    "version",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "quality.criteria.v1"
    },
    "criteria_id": {
      "type": "string",
      "pattern": "^QC-[A-Z0-9_-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^v[0-9]+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "rule_base": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "severity",
        "type",
        "params"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.-]{2,64}$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "block",
            "warn"
          ]
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "object"
        },
        "extensions": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "rule_json_pointer_required": {
      "allOf": [
        {
          "$ref": "#/$defs/rule_base"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "json_pointer_required"
            },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "pointer"
              ],
              "properties": {
                "pointer": {
                  "type": "string",
                  "pattern": "^/.*"
                }
              }
            }
          }
        }
      ]
    },
    "rule_regex_match": {
      "allOf": [
        {
          "$ref": "#/$defs/rule_base"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "regex_match"
            },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "pointer",
                "pattern"
              ],
              "properties": {
                "pointer": {
                  "type": "string",
                  "pattern": "^/.*"
                },
                "pattern": {
                  "type": "string",
                  "minLength": 1
                },
                "flags": {
                  "type": "string",
                  "minLength": 0
                }
              }
            }
          }
        }
      ]
    },
    "rule_metric_threshold": {
      "allOf": [
        {
          "$ref": "#/$defs/rule_base"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "metric_threshold"
            },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "metric",
                "operator",
                "value"
              ],
              "properties": {
                "metric": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                },
                "operator": {
                  "type": "string",
                  "enum": [
                    "<",
                    "<=",
                    "==",
                    ">=",
                    ">"
                  ]
                },
                "value": {
                  "type": "number"
                },
                "unit": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 32
                }
              }
            }
          }
        }
      ]
    },
    "rule_llm_judge_score": {
      "allOf": [
        {
          "$ref": "#/$defs/rule_base"
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "const": "llm_judge_score"
            },
            "params": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "rubric_id",
                "min_score"
              ],
              "properties": {
                "rubric_id": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                },
                "min_score": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "model_ref": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                }
              }
            }
          }
        }
      ]
    },
    "rule": {
      "oneOf": [
        {
          "$ref": "#/$defs/rule_json_pointer_required"
        },
        {
          "$ref": "#/$defs/rule_regex_match"
        },
        {
          "$ref": "#/$defs/rule_metric_threshold"
        },
        {
          "$ref": "#/$defs/rule_llm_judge_score"
        }
      ]
    }
  },
  "examples": [
    {
      "schema_version": "quality.criteria.v1",
      "criteria_id": "QC-CORE",
      "version": "v1",
      "description": "WF-CORE kalite kriterleri",
      "rules": [
        {
          "id": "analysis_summary_required",
          "severity": "block",
          "type": "json_pointer_required",
          "params": {
            "pointer": "/analysis_summary"
          }
        },
        {
          "id": "max_tokens_out",
          "severity": "warn",
          "type": "metric_threshold",
          "params": {
            "metric": "tokens_out",
            "operator": "<=",
            "value": 1500,
            "unit": "tokens"
          }
        }
      ]
    }
  ]
}
