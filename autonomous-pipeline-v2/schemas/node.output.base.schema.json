{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Node Output Base (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "node",
    "status"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "node.output.base.v1"
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "type": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        }
      }
    },
    "run": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "run_id": {
          "type": "string",
          "format": "uuid"
        },
        "attempt": {
          "type": "integer",
          "minimum": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "failure",
        "skipped"
      ]
    },
    "outputs": {
      "type": "object",
      "additionalProperties": true
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "details": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "tokens_in": {
          "type": "integer",
          "minimum": 0
        },
        "tokens_out": {
          "type": "integer",
          "minimum": 0
        },
        "cost_usd": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "side_effects": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "mode",
          "target",
          "result"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "file_write",
              "http_request",
              "message_publish",
              "db_write"
            ]
          },
          "mode": {
            "type": "string",
            "enum": [
              "deny",
              "draft",
              "commit",
              "allow"
            ]
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "blocked",
              "skipped",
              "success",
              "failure"
            ]
          },
          "diff_ref": {
            "type": "string",
            "minLength": 1
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "evidence": {
      "type": "object",
      "additionalProperties": true
    },
    "quality": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bias": {
          "$ref": "bias_report.v1.schema.json"
        }
      }
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "node": {
            "properties": {
              "type": {
                "const": "approval"
              }
            },
            "required": [
              "type"
            ]
          }
        }
      },
      "then": {
        "required": [
          "outputs"
        ],
        "properties": {
          "outputs": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "approved"
            ],
            "properties": {
              "approved": {
                "type": "boolean"
              },
              "decision": {
                "type": "string",
                "enum": [
                  "approved",
                  "rejected",
                  "human_review",
                  "timeout"
                ]
              },
              "reason": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  ]
}
