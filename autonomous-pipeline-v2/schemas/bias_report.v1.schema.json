{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bias Report (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "decision"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "bias.report.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "policy_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "model_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "unit_of_analysis": {
      "type": "string",
      "enum": [
        "individual_decision",
        "session",
        "aggregate"
      ],
      "default": "individual_decision"
    },
    "window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "string",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "format": "date-time"
        },
        "window_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "dataset_ref": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "protected_attributes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    },
    "group_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "total_n",
          "groups"
        ],
        "properties": {
          "total_n": {
            "type": "integer",
            "minimum": 0
          },
          "groups": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "group",
                "n"
              ],
              "properties": {
                "group": {
                  "type": "string",
                  "minLength": 1,
                  "maxLength": 128
                },
                "n": {
                  "type": "integer",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    },
    "metrics": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/metric_result"
      }
    },
    "decision": {
      "type": "string",
      "enum": [
        "passed",
        "blocked",
        "human_review",
        "insufficient_data",
        "error"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "raw": {
      "type": "object",
      "additionalProperties": true
    },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "metric_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric",
        "attribute",
        "value",
        "threshold_max_abs_diff",
        "passed"
      ],
      "properties": {
        "metric": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "attribute": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "value": {
          "type": "number"
        },
        "threshold_max_abs_diff": {
          "type": "number",
          "minimum": 0
        },
        "passed": {
          "type": "boolean"
        }
      }
    }
  },
  "examples": [
    {
      "schema_version": "bias.report.v1",
      "generated_at": "2025-12-30T00:00:00Z",
      "policy_ref": "policy.ethics@v1",
      "model_ref": "model:llm-primary@v2025-12-30",
      "unit_of_analysis": "individual_decision",
      "window": {
        "start": "2025-12-01T00:00:00Z",
        "end": "2025-12-30T00:00:00Z",
        "window_days": 30
      },
      "dataset_ref": "dataset:prod_requests@v1",
      "protected_attributes": [
        "gender"
      ],
      "group_counts": {
        "gender": {
          "total_n": 1200,
          "groups": [
            {
              "group": "female",
              "n": 540
            },
            {
              "group": "male",
              "n": 660
            }
          ]
        }
      },
      "metrics": [
        {
          "metric": "demographic_parity_diff",
          "attribute": "gender",
          "value": 0.02,
          "threshold_max_abs_diff": 0.05,
          "passed": true
        }
      ],
      "decision": "passed",
      "reasons": []
    }
  ]
}
