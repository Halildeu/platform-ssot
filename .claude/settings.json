{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "TodoWrite",
      "Bash(python -m src.*)",
      "Bash(python3 -m src.*)",
      "Bash(python ci/*)",
      "Bash(python3 ci/*)",
      "Bash(python -m pytest*)",
      "Bash(python3 -m pytest*)",
      "Bash(python scripts/*)",
      "Bash(python3 scripts/*)",
      "Bash(pip install*)",
      "Bash(pip3 install*)",
      "Bash(git *)",
      "Bash(gh *)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(env)",
      "Bash(echo *)",
      "Bash(date*)",
      "Bash(jq *)",
      "Bash(cd *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(docker *)",
      "Bash(docker-compose*)",
      "Bash(kill-port *)",
      "Bash(lsof *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(tar *)",
      "Bash(zip *)",
      "Bash(unzip *)",
      "Bash(python3 *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(black *)",
      "Bash(mypy *)"
    ],
    "deny": [
      "Bash(rm -rf /)*",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(docker rm*)",
      "Bash(docker rmi*)"
    ]
  },
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 -c \"import json,pathlib;p=pathlib.Path('.cache/ws_customer_default/.cache/reports/system_status.v1.json');d=json.loads(p.read_text()) if p.exists() else {};print(f'[Context Restore] System: {d.get(\"overall_status\",\"unknown\")}')\" 2>/dev/null || echo '[Context Restore] system_status not available'",
            "statusMessage": "Restoring context after compaction..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ci/validate_schemas.py 2>&1 | tail -3",
            "statusMessage": "Validating schemas before commit..."
          }
        ]
      }
    ]
  }
}
