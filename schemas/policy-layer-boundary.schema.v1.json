{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-layer-boundary.schema.v1.json",
  "title": "policy-layer-boundary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "enforcement_mode",
    "core_roots",
    "catalog_roots",
    "workspace_root_required"
  ],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "enforcement_mode": { "type": "string", "enum": ["fail_closed"] },
    "core_roots": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "catalog_roots": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "workspace_root_required": { "type": "boolean" },
    "external_write_allowlist": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
