{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-kernel-api-guardrails.schema.json",
  "title": "Policy Kernel API Guardrails",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "auth", "limits", "actions", "audit"],
  "properties": {
    "version": {"type": "string", "enum": ["v1"]},
    "auth": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "env_key", "required"],
      "properties": {
        "mode": {"type": "string", "enum": ["bearer", "hmac"]},
        "env_key": {"type": "string", "minLength": 1},
        "required": {"type": "boolean"}
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_body_bytes", "max_json_depth", "rate_limit_per_minute", "max_concurrent"],
      "properties": {
        "max_body_bytes": {"type": "integer", "minimum": 1, "maximum": 10485760},
        "max_json_depth": {"type": "integer", "minimum": 1, "maximum": 200},
        "rate_limit_per_minute": {"type": "integer", "minimum": 0, "maximum": 100000},
        "max_concurrent": {"type": "integer", "minimum": 1, "maximum": 1024}
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowlist", "llm_call_live_allowed"],
      "properties": {
        "allowlist": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1,
          "uniqueItems": true
        },
        "llm_call_live_allowed": {"type": "boolean"}
      }
    },
    "audit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "path", "redact_keys", "store_request_preview"],
      "properties": {
        "enabled": {"type": "boolean"},
        "path": {"type": "string", "minLength": 1},
        "redact_keys": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1
        },
        "store_request_preview": {"type": "boolean"}
      }
    }
  }
}
