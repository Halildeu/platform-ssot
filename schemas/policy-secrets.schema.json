{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/policy-secrets.schema.json",
  "title": "Policy Secrets",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "provider", "allowed_secret_ids"],
  "properties": {
    "version": { "type": "string", "enum": ["v1"] },
    "provider": { "type": "string", "enum": ["env", "vault_stub"] },
    "allowed_secret_ids": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{2,64}$" },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
