{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "repo-layout.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "allowed_top_level_dirs",
    "allowed_top_level_files",
    "generated_dirs",
    "generated_files_patterns",
    "notes"
  ],
  "properties": {
    "version": {
      "const": "v1"
    },
    "allowed_top_level_dirs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "allowed_top_level_files": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "generated_dirs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "generated_files_patterns": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
