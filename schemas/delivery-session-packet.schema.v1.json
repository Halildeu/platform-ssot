{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/delivery-session-packet.schema.v1.json",
  "title": "Delivery Session Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "kind",
    "generated_at",
    "repo_root",
    "source_contract_path",
    "feature_id",
    "title",
    "active_scopes",
    "affected_modules",
    "allowed_write_paths",
    "required_read_paths",
    "lane_plan",
    "write_plan",
    "ux_context",
    "stop_conditions",
    "evidence_targets",
    "notes"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": ["v1"]
    },
    "kind": {
      "type": "string",
      "enum": ["delivery-session-packet"]
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "source_contract_path": {
      "type": "string",
      "minLength": 1
    },
    "feature_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "active_scopes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["backend", "database", "api", "frontend"]
      }
    },
    "affected_modules": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_write_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_read_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "lane_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "execution_sequence",
        "active_lanes",
        "lane_commands"
      ],
      "properties": {
        "execution_sequence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["backend", "database", "api", "frontend", "integration", "e2e"]
          }
        },
        "active_lanes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["unit", "database", "api", "contract", "integration", "e2e"]
          }
        },
        "lane_commands": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "write_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "phase",
          "lane",
          "write_globs",
          "read_paths",
          "command",
          "notes"
        ],
        "properties": {
          "phase": {
            "type": "string",
            "enum": ["backend", "database", "api", "frontend", "integration", "e2e"]
          },
          "lane": {
            "type": "string",
            "enum": ["unit", "database", "api", "contract", "integration", "e2e"]
          },
          "write_globs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "read_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "ux_context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "artifact_count",
        "change_map_path",
        "artifacts"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["REQUIRED", "NOT_APPLICABLE"]
        },
        "artifact_count": {
          "type": "integer",
          "minimum": 0
        },
        "change_map_path": {
          "type": "string",
          "minLength": 1
        },
        "artifacts": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "path_glob",
              "ux_theme_id",
              "ux_subtheme_id"
            ],
            "properties": {
              "path_glob": {
                "type": "string",
                "minLength": 1
              },
              "ux_theme_id": {
                "type": "string",
                "minLength": 1
              },
              "ux_subtheme_id": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
