$ GET /api/v1/users (no token)
HTTP/1.1 401 Unauthorized
connection: keep-alive
content-length: 123
content-type: application/json
keep-alive: timeout=5

{
  "path": "/api/v1/users",
  "traceId": "smoke-401",
  "hasAuth": false,
  "authHeader": "",
  "error": "auth_required"
}

$ GET /api/v1/users (demo token)
HTTP/1.1 200 OK
connection: keep-alive
content-length: 138
content-type: application/json
keep-alive: timeout=5

{
  "path": "/api/v1/users",
  "traceId": "smoke-200",
  "hasAuth": true,
  "authHeader": "Bearer demo-token",
  "message": "gateway-ok"
}