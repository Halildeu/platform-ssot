{
  "version": "v1",
  "kind": "policy-work-intake-rules-fragment",
  "fragment_id": "github_ops",
  "source_types": [
    "GITHUB_OPS"
  ],
  "rules": [
    {
      "id": "github_ops_index_lock",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_signal_in": [
          "index_lock"
        ]
      },
      "bucket": "INCIDENT",
      "severity": "S1",
      "priority": "P1",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_dirty_tree",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_signal_in": [
          "dirty_tree"
        ]
      },
      "bucket": "TICKET",
      "severity": "S3",
      "priority": "P3",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_behind_remote",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_signal_in": [
          "behind_remote"
        ]
      },
      "bucket": "TICKET",
      "severity": "S3",
      "priority": "P3",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_live_gate_disabled",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_signal_in": [
          "live_gate_disabled"
        ]
      },
      "bucket": "TICKET",
      "severity": "S4",
      "priority": "P4",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_job_pass_auto_close",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_job_status_in": [
          "PASS"
        ]
      },
      "bucket": "TICKET",
      "severity": "S4",
      "priority": "P4",
      "auto_close": true,
      "closed_reason": "GITHUB_OPS_JOB_PASS",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_job_demo_prereq_fail",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_job_status_in": [
          "FAIL"
        ],
        "github_ops_job_failure_class_in": [
          "DEMO_PREREQ_FAIL"
        ]
      },
      "bucket": "TICKET",
      "severity": "S2",
      "priority": "P2",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_job_demo_prereq_apply_fail",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_job_status_in": [
          "FAIL"
        ],
        "github_ops_job_failure_class_in": [
          "DEMO_PREREQ_APPLY_FAIL"
        ]
      },
      "bucket": "TICKET",
      "severity": "S2",
      "priority": "P2",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_job_demo_catalog_parse",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_job_status_in": [
          "FAIL"
        ],
        "github_ops_job_failure_class_in": [
          "DEMO_CATALOG_PARSE"
        ]
      },
      "bucket": "TICKET",
      "severity": "S2",
      "priority": "P2",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_job_demo_catalog_missing",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_job_status_in": [
          "FAIL"
        ],
        "github_ops_job_failure_class_in": [
          "DEMO_CATALOG_MISSING"
        ]
      },
      "bucket": "TICKET",
      "severity": "S2",
      "priority": "P2",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_job_demo_advisor_missing",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_job_status_in": [
          "FAIL"
        ],
        "github_ops_job_failure_class_in": [
          "DEMO_ADVISOR_SUGGESTIONS_MISSING"
        ]
      },
      "bucket": "TICKET",
      "severity": "S2",
      "priority": "P2",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_job_core_break",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_job_status_in": [
          "FAIL"
        ],
        "github_ops_job_failure_class_in": [
          "CORE_BREAK"
        ]
      },
      "bucket": "INCIDENT",
      "severity": "S1",
      "priority": "P1",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_job_policy_time_limit",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_job_status_in": [
          "FAIL"
        ],
        "github_ops_job_failure_class_in": [
          "POLICY_TIME_LIMIT"
        ]
      },
      "bucket": "TICKET",
      "severity": "S2",
      "priority": "P2",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_job_fail_other",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_job_status_in": [
          "FAIL"
        ],
        "github_ops_job_failure_class_in": [
          "OTHER"
        ]
      },
      "bucket": "TICKET",
      "severity": "S2",
      "priority": "P2",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_job_timeout",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_job_status_in": [
          "TIMEOUT",
          "KILLED"
        ]
      },
      "bucket": "TICKET",
      "severity": "S2",
      "priority": "P2",
      "suggested_extension": "PRJ-GITHUB-OPS"
    },
    {
      "id": "github_ops_job_skip_no_network",
      "source_type": "GITHUB_OPS",
      "when": {
        "github_ops_job_status_in": [
          "SKIP"
        ],
        "github_ops_job_skip_reason_in": [
          "NO_NETWORK",
          "LIVE_GATE_DISABLED",
          "AUTH_MISSING",
          "NETWORK_DISABLED"
        ]
      },
      "bucket": "TICKET",
      "severity": "S4",
      "priority": "P4",
      "suggested_extension": "PRJ-GITHUB-OPS"
    }
  ]
}
