{
  "version": "v1",
  "kind": "policy-ui-design-system",
  "status": "ACTIVE",
  "owner": "frontend-platform",
  "purpose": "Tek tasarim kutuphanesi, moduler sayfa kompozisyonu ve parametrik veri kontratini drift'e kapatir.",
  "enforcement_mode": "blocking",
  "ci_lane": "contract",
  "single_ui_library": {
    "package_name": "mfe-ui-kit",
    "package_manifest_path": "web/packages/ui-kit/package.json",
    "design_catalog_index_path": "web/apps/mfe-shell/src/pages/admin/design-lab.index.json",
    "required_npm_scripts": [
      "lint:no-antd",
      "tokens:build",
      "designlab:index"
    ],
    "forbidden_imports": [
      "antd",
      "@ant-design/icons"
    ]
  },
  "design_tokens": {
    "source_path": "web/design-tokens/figma.tokens.json",
    "generated_paths": [
      "web/apps/mfe-shell/src/styles/theme.css",
      "web/design-tokens/generated/theme-contract.json"
    ],
    "check_command": "node web/scripts/theme/generate-theme-css.mjs --check"
  },
  "page_modularity": {
    "layout_exports_required": [
      "PageLayout",
      "DetailDrawer",
      "FormDrawer"
    ],
    "ui_usage_import_prefix": "from 'mfe-ui-kit'",
    "pages_root": "web/apps"
  },
  "parametric_data": {
    "query_builder_path": "web/packages/ui-kit/src/components/entity-grid/buildEntityGridQueryParams.ts",
    "theme_contract_runtime_path": "web/packages/ui-kit/src/runtime/theme-contract.ts",
    "theme_context_provider_path": "web/apps/mfe-shell/src/app/theme/theme-context.provider.tsx"
  }
}
