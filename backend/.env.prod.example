# Canonical Vault path: secret/<env>/backend-deploy/config
# Render the real backend.env on Ubuntu from Vault-backed values with:
#   deploy/ubuntu/render-backend-env.sh
# Suggested target path: /home/halil/platform/env/backend.env
# Do not commit the rendered file.

# Git / GHCR
GIT_REMOTE_URL=https://github.com/Halildeu/platform-ssot.git
REPO_BRANCH=main
GHCR_OWNER=halildeu
IMAGE_TAG=main-stable

# Runtime
COMPOSE_PROJECT_NAME=platform
TZ=Europe/Istanbul
COMPOSE_PROFILES=
API_GATEWAY_PORT=8080

# External security dependencies
VAULT_URI=https://vault.example.com:8200
VAULT_SCHEME=https
VAULT_TOKEN=rendered-from-vault
VAULT_FAIL_FAST=true

KEYCLOAK_ISSUER_URI=https://auth.example.com/realms/serban
KEYCLOAK_JWKS_URI=https://auth.example.com/realms/serban/protocol/openid-connect/certs
WEB_ORIGIN=https://app.example.com
AUTH_VERIFICATION_BASE_URL=https://app.example.com/verify-email
AUTH_RESET_BASE_URL=https://app.example.com/reset-password

# Shared service auth
SERVICE_CLIENT_USER_SERVICE_SECRET=rendered-from-vault
PERMISSION_SERVICE_INTERNAL_API_KEY=rendered-from-vault
SECURITY_AUTH_ALLOWED_CLIENT_IDS=frontend,admin-cli,serban-web

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=rendered-from-vault
POSTGRES_DB=users
AUTH_DB_SCHEMA=auth_service
USER_DB_SCHEMA=user_service
PERMISSION_DB_SCHEMA=permission_service
VARIANT_DB_SCHEMA=variant_service
CORE_DATA_DB_SCHEMA=core_data_service

# OpenFGA
OPENFGA_STORE_ID=replace-me
OPENFGA_MODEL_ID=replace-me
OPENFGA_LOG_LEVEL=info

# Services that still read DB config directly from env.
# Keep the source of truth in Vault, then materialize this file during deploy.
CORE_DATA_DB_URL=jdbc:postgresql://postgres-db:5432/users
CORE_DATA_DB_USERNAME=postgres
CORE_DATA_DB_PASSWORD=rendered-from-vault

# Optional report / schema services
REPORT_MSSQL_HOST=sql.example.internal
REPORT_MSSQL_PORT=1433
REPORT_MSSQL_DB=reporting
REPORT_MSSQL_USERNAME=readonly
REPORT_MSSQL_PASSWORD=rendered-from-vault
REPORT_PG_HOST=postgres-db
REPORT_PG_PORT=5432
REPORT_PG_DB=users
REPORT_PG_USERNAME=postgres
REPORT_PG_PASSWORD=rendered-from-vault

SCHEMA_MSSQL_HOST=sql.example.internal
SCHEMA_MSSQL_PORT=1433
SCHEMA_MSSQL_DB=workcube_mikrolink
SCHEMA_MSSQL_USERNAME=readonly
SCHEMA_MSSQL_PASSWORD=rendered-from-vault
SCHEMA_DEFAULT_SCHEMA=workcube_mikrolink
