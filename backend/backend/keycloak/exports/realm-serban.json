        "audience-permission-service",
        "audience-variant-service",
        "frontend-dedicated"
      ],
      "protocolMappers": [
        {
          "name": "permissions-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-javascript-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "id.token.claim": "false",
            "userinfo.token.claim": "false",
            "claim.name": "permissions",
            "jsonType.label": "String",
            "multivalued": "true",
            "script": "var permissions = [];\nvar append = function(value) {\n  if (permissions.indexOf(value) === -1) {\n    permissions.push(value);\n  }\n};\nvar roles = user.getRoleMappings();\nvar it = roles.iterator();\nwhile (it.hasNext()) {\n  var role = it.next();\n  var attrs = role.getAttributes();\n  if (attrs != null && attrs.containsKey('permissions')) {\n    var values = attrs.get('permissions');\n    var permIterator = values.iterator();\n    while (permIterator.hasNext()) {\n      append(String(permIterator.next()));\n    }\n  }\n}\nif (permissions.length > 0) {\n  token.setOtherClaims('permissions', permissions);\n}"
          }
        }
      ]
    }
  ]
