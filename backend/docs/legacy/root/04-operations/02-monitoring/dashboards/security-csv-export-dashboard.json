{
  "uid": "SEC-EXPORT-001",
  "title": "Security / CSV Export Guard",
  "tags": ["security", "export"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "7d"]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "grafana"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "templating": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Rate limit throughput (allowed vs blocked)",
      "gridPos": {"h": 9, "w": 24, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "req/s",
          "custom": {
            "stacking": {"mode": "normal", "group": "A"},
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 35
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(users_export_rate_limit_total{result=\"allowed\"}[5m]))",
          "legendFormat": "allowed",
          "range": true
        },
        {
          "refId": "B",
          "expr": "sum(rate(users_export_rate_limit_total{result=\"blocked\"}[5m]))",
          "legendFormat": "blocked",
          "range": true
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Blocked / allowed oranı",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 9},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 0.02},
              {"color": "red", "value": 0.05}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(users_export_rate_limit_total{result=\"blocked\"}[5m])) / clamp_min(sum(rate(users_export_rate_limit_total{result=\"allowed\"}[5m])), 0.001)",
          "legendFormat": "blocked / allowed",
          "range": true
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Export süresi p95",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 9},
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "list", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(users_export_duration_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "range": true
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Audit failure artışı",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 17},
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {"displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "single"}
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(users_export_audit_total{result=\"failure\"}[5m]))",
          "legendFormat": "failure (5m)",
          "range": true
        },
        {
          "refId": "B",
          "expr": "sum(increase(users_export_audit_total{result=\"success\"}[5m]))",
          "legendFormat": "success (5m)",
          "range": true
        }
      ]
    }
  ]
}
