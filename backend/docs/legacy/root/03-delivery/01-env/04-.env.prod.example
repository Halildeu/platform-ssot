##############################
# Production Environment (.env)
##############################

# --- Gateway ---
SECURITY_JWT_JWK_SET_URI=https://keycloak.example.com/realms/platform/protocol/openid-connect/certs
SECURITY_JWT_ISSUER=https://keycloak.example.com/realms/platform
SECURITY_JWT_AUDIENCE=user-service,permission-service,variant-service

# --- user-service ---
SECURITY_JWT_JWK_SET_URI=https://keycloak.example.com/realms/platform/protocol/openid-connect/certs
SECURITY_JWT_USER_JWK_SET_URI=https://keycloak.example.com/realms/platform/protocol/openid-connect/certs
SECURITY_JWT_ISSUER=https://keycloak.example.com/realms/platform
SECURITY_JWT_AUDIENCE=user-service

# --- permission-service ---
SECURITY_JWT_JWK_SET_URI=https://keycloak.example.com/realms/platform/protocol/openid-connect/certs
SECURITY_JWT_USER_JWK_SET_URI=https://keycloak.example.com/realms/platform/protocol/openid-connect/certs
SECURITY_JWT_ISSUER=https://keycloak.example.com/realms/platform
SECURITY_JWT_AUDIENCE=permission-service

# --- variant-service ---
SECURITY_JWT_JWK_SET_URI=https://keycloak.example.com/realms/platform/protocol/openid-connect/certs
SECURITY_JWT_ISSUER=https://keycloak.example.com/realms/platform
SECURITY_JWT_AUDIENCE=variant-service

# --- Vault ---
SPRING_CLOUD_VAULT_ENABLED=true
SPRING_CLOUD_VAULT_KV_ENABLED=true
SPRING_CLOUD_VAULT_FAIL_FAST=true
VAULT_ADDR=https://vault.example.com:8200
# Prod’da AppRole/JWT auth kullanın. Token’ı CI/CD secret store’dan enjekte edin.
SPRING_CLOUD_VAULT_TOKEN=
SPRING_CLOUD_VAULT_SCHEME=https

# --- Databases (örnek) ---
PERMISSION_DB_URL=jdbc:postgresql://pg.example.com:5432/permissions
PERMISSION_DB_USERNAME=${PERMISSION_DB_USERNAME}
PERMISSION_DB_PASSWORD=${PERMISSION_DB_PASSWORD}
VARIANT_DB_URL=jdbc:postgresql://pg.example.com:5432/variants
VARIANT_DB_USERNAME=${VARIANT_DB_USERNAME}
VARIANT_DB_PASSWORD=${VARIANT_DB_PASSWORD}
