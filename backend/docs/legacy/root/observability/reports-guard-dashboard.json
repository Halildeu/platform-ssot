{
  "uid": "OPS-REPORTS-GUARD-001",
  "title": "Operations / Reports Guard",
  "tags": ["operations", "reports", "guard"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "7d"]
  },
  "annotations": {"list": [{"builtIn": 1, "datasource": {"type": "grafana", "uid": "grafana"}, "enable": true, "hide": true, "iconColor": "rgba(0, 211, 255, 1)", "name": "Annotations & Alerts", "type": "dashboard"}]},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Reports guard hits by result (Loki)",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 8},
      "fieldConfig": {"defaults": {"unit": "req/s"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate({app=\"api-gateway\"} |= \"/admin/reports/\" [5m]))",
          "legendFormat": "{{result}}",
          "range": true
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Unauthorized ratio (Loki)",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"x": 0, "y": 8, "w": 24, "h": 8},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate({app=\"api-gateway\"} |= \"/admin/reports/\" |= \" 401 \" [5m])))/(clamp_min(sum(rate({app=\"api-gateway\"} |= \"/admin/reports/\" [5m])), 0.001))",
          "legendFormat": "unauthorized ratio",
          "range": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Last 5m unauthorized (count)",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"x": 0, "y": 16, "w": 8, "h": 6},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=\"api-gateway\"} |= \"/admin/reports/\" |= \" 401 \" [5m]))",
          "legendFormat": "401"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last 5m allowed (count)",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"x": 8, "y": 16, "w": 8, "h": 6},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({app=\"api-gateway\"} |= \"/admin/reports/\" |~ \" 200|302 \" [5m]))",
          "legendFormat": "allowed"
        }
      ]
    },
    {
      "id": 5,
      "type": "text",
      "title": "Notes",
      "gridPos": {"x": 16, "y": 16, "w": 8, "h": 6},
      "options": {"content": "Datasource UID'lerini ortamınıza göre güncelleyin (loki). Gateway log label/formatı farklıysa sorguları uyarlayın.", "mode": "markdown"}
    }
    ,
    {
      "id": 6,
      "type": "table",
      "title": "Top paths by result (last 5m)",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"x": 0, "y": 22, "w": 24, "h": 8},
      "fieldConfig": {"defaults": {"custom": {"align": "auto"}}, "overrides": []},
      "options": {"showHeader": true},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (result, path) (count_over_time({app=\"api-gateway\"} |= \"/admin/reports/\" [5m])))",
          "legendFormat": "{{result}} {{path}}",
          "range": true
        }
      ]
    }
    ,
    {
      "id": 7,
      "type": "stat",
      "title": "Unauthorized ratio (stat, Loki)",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"x": 0, "y": 30, "w": 8, "h": 6},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "targets": [
        {
          "refId": "A",
          "expr": "(sum(rate({app=\"api-gateway\"} |= \"/admin/reports/\" |= \" 401 \" [5m])))/(clamp_min(sum(rate({app=\"api-gateway\"} |= \"/admin/reports/\" [5m])), 0.001))",
          "legendFormat": "unauthorized ratio"
        }
      ]
    }
    ,
    {
      "id": 8,
      "type": "bargauge",
      "title": "Unauthorized by path (json parsed, last 5m)",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"x": 8, "y": 30, "w": 16, "h": 6},
      "options": {"displayMode": "basic", "orientation": "horizontal"},
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (path) (count_over_time({app=\"api-gateway\"} | json | path=~\"/admin/reports/.*\" |~ \" 401 \" [5m])))",
          "legendFormat": "{{path}}",
          "range": true
        }
      ]
    }
  ]
}
